# ============================================================
# Blog Writer Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# API key used to authenticate POST /webhook requests
# Must be a long, random string (e.g. generated with: openssl rand -hex 32)
API_KEY=your-secret-api-key-here

# Absolute or relative path to the Google service account JSON credentials file
# The service account needs: Google Drive, Google Docs, Google Sheets, Vertex AI permissions
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Google Cloud project ID for Vertex AI (Gemini)
VERTEX_AI_PROJECT=your-gcp-project-id

# Vertex AI region (e.g. us-central1)
VERTEX_AI_LOCATION=us-central1
